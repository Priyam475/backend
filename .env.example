# Environment Variables Template
# Copy this file to .env and fill in with actual values

# ===================================================================
# Database Configuration (Required)
# ===================================================================
DATABASE_URL=jdbc:postgresql://localhost:5432/mercotrace
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_POOL_SIZE=10

# ===================================================================
# Spring Boot Configuration
# ===================================================================
SPRING_PROFILES_ACTIVE=prod
APPLICATION_CACHE_REDIS_ENABLED=false
SPRING_CACHE_TYPE=simple

# ===================================================================
# Security Configuration (REQUIRED for production)
# ===================================================================
# Generate with: openssl rand -base64 64
# Change this before deploying to production!
JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=MjQwMjlmMDVhODg4MDUwZGJjMDllZjU5Njg3NGY3MGZjOTlkNjU0MjU5YmJlYzVjMTA5ZDEwYjlkMTM3OGE5ZmM0ZThkNWVjY2MwNmRhZjI0OTc2ZDFiZjE0ZDk2ZGMyZDk3MzY4NWFkYWRlNzlkNDdhZDQ4ODE2OTA0MjE4NzE=

# ===================================================================
# Mail Configuration (Optional)
# ===================================================================
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=

# ===================================================================
# JHipster Mail Base URL
# ===================================================================
JHIPSTER_MAIL_BASE_URL=http://localhost:8080

# ===================================================================
# Redis Configuration (if caching is enabled)
# ===================================================================
REDIS_URL=redis://localhost:6379

# ===================================================================
# For Render Deployment - Use these values
# ===================================================================
# DATABASE_URL=postgresql://[user]:[password]@[render-host]:[port]/[database]
# DATABASE_USER=render_user
# DATABASE_PASSWORD=render_password
# JHIPSTER_MAIL_BASE_URL=https://your-app.render.com
