<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Add GST rate and weighing threshold columns to commodity_config.
         These are nullable and fully backward compatible with existing data. -->
    <changeSet id="20260307130000-commodity-config-gst-rate-threshold" author="mercotrace">
        <addColumn tableName="commodity_config">
            <column name="gst_rate" type="double precision"/>
            <column name="weighing_threshold" type="double precision"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>

