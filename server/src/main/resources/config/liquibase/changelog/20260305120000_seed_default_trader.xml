<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Seed a single default trader (id=1) used by Module1AuthResource for prod logins -->
    <changeSet id="20260305120000-1" author="cursor" context="prod">
        <preConditions onFail="MARK_RAN">
            <!-- Skip if a trader with id=1 already exists -->
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM trader WHERE id = 1;
            </sqlCheck>
        </preConditions>

        <insert tableName="trader">
            <column name="id" valueNumeric="1"/>
            <column name="business_name" value="Default Mandi Trader"/>
            <column name="owner_name" value="Super Admin"/>
            <column name="address" value="Configured via backend seed"/>
            <column name="category" value="Agriculture"/>
            <column name="approval_status" value="APPROVED"/>
            <column name="business_mode" value="COMMISSION"/>
            <column name="bill_prefix" value="MT"/>
            <column name="created_at" valueDate="2026-03-05T00:00:00"/>
            <column name="updated_at" valueDate="2026-03-05T00:00:00"/>
        </insert>
    </changeSet>

</databaseChangeLog>

