<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Trader active flag: when false, trader (and their staff) cannot login.
        Admin can mark traders inactive; inactive traders can be permanently deleted.
    -->
    <changeSet id="20260319120000-trader-active" author="cursor-ai">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="trader" columnName="active"/>
            </not>
        </preConditions>
        <addColumn tableName="trader">
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
