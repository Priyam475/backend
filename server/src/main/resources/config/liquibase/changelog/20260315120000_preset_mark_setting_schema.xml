<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260315120000-1" author="mercotrace">
        <createTable tableName="preset_mark_setting">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trader_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="predefined_mark" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="extra_amount" type="numeric(19,2)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="preset_mark_setting" indexName="idx_preset_mark_setting_trader">
            <column name="trader_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
