<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog-ext/dbchangelog-ext.xsd">

    <!--
        Added the entity Commodity (Module: Commodity Settings).
        Aligned with frontend Commodity model in client/src/types/models.ts.
    -->
    <changeSet id="20260225120000-1" author="jhipster">
        <createTable tableName="commodity">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trader_id" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="commodity_name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="commodity"
                             columnNames="trader_id, commodity_name"
                             constraintName="ux_commodity_trader_name"/>

        <createIndex tableName="commodity" indexName="idx_commodity_trader">
            <column name="trader_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
